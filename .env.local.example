# Copy this file to ".env.local" and fill in the values from your Supabase project.
# Supabase Dashboard -> Project Settings -> API

# Public values (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Secret values (server only — NEVER prefix with NEXT_PUBLIC)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Admin password — must match the password in app/lib/auth.ts.
# Used to authorize admin-only API routes (reading/deleting messages).
ADMIN_PASSWORD=Asingiro8!
